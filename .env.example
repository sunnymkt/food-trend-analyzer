# scripts/fetch_naver_trends.py 를 로컬에서 실행할 때 사용합니다.
# 이 파일을 .env 로 복사한 뒤 실제 값을 채워넣으세요. (.env 는 git에 커밋되지 않습니다)
#
# 발급: https://developers.naver.com/apps/#/register  (검색 > 데이터랩(검색어트렌드) API 사용 설정)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# scripts/fetch_related_keywords.py (지정 키워드의 관련 인기검색어) 용.
# 데이터랩 키와는 별개로, https://searchad.naver.com 에서 광고주 가입 후
# [도구 > API 사용 관리]에서 발급받습니다.
NAVER_AD_API_KEY=
NAVER_AD_SECRET_KEY=
NAVER_AD_CUSTOMER_ID=

# scripts/generate_weekly_report.py (주간 리포트 이메일 발송)용.
# 회사 메일서버의 SMTP 접속정보를 IT부서에 문의해서 채워넣으세요.
# 포트가 465면 SMTPS(SSL)로, 그 외(587 등)는 STARTTLS로 접속합니다.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# 발신자 표시 주소. 비워두면 SMTP_USER를 그대로 씁니다.
SMTP_FROM=
# 받는 사람 이메일. 여러 명이면 콤마로 구분 (예: a@nhfood.co.kr,b@nhfood.co.kr)
REPORT_RECIPIENTS=shkim@nhfood.co.kr
